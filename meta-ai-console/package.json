{
  "name": "meta-ai-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "build:boot": "vue-tsc -b && vite build --mode boot",
    "build:prod": "vue-tsc -b && vite build --mode production",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc -b",
    "lint": "npm run lint:oxlint && npm run lint:eslint",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "axios": "^1.7.9",
    "dompurify": "^3.4.8",
    "lucide-vue-next": "^0.552.0",
    "markdown-it": "^14.2.0",
    "naive-ui": "^2.40.3",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.70.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "oxlint": "^1.70.0",
    "prettier": "3.8.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.0"
  }
}
