# 生产页面挂在 Nginx /meta-ai/ 前缀下
# 老系统 iframe 使用 /meta-ai/embed/chat?tenantId=t1&userId=u1&kbId=kb1
VITE_APP_BASE_PATH=/meta-ai/

# 生产 API 挂在 Nginx /api/meta-ai 前缀下
# Nginx 会把 /api/meta-ai/v1/** 转发为 Spring Boot 内部 /v1/**
# URL query 只作为嵌入上下文入口，不作为可信身份凭证
VITE_API_BASE_URL=/api/meta-ai

# 当前后端开发期 API Token 仍用于 POST /v1/chat、/v1/rag 和文件上传
# VITE_ 变量会进入浏览器构建产物，生产环境不能把它当作真正安全凭证
VITE_METAX_API_TOKEN=sk-metax-123456
