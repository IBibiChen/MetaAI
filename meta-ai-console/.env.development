# 本地开发页面从 Vite dev server 根路径访问
VITE_APP_BASE_PATH=/

# 本地开发 API 走 Vite proxy
# /api/v1/** 会转发到 Spring Boot 后端 /v1/**
VITE_API_BASE_URL=/api

# 本地开发轻量 API Token，必须与后端 metax.ai.security.api-token 保持一致
# VITE_ 变量会进入浏览器构建产物，不能作为生产安全凭证
VITE_METAX_API_TOKEN=sk-metax-123456

# 本地开发 ASR WebSocket 地址，默认连接本机 FunASR Runtime
VITE_ASR_WS_URL=ws://localhost:10096
