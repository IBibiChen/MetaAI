COMPOSE_PROJECT_NAME=meta-ai-ollama

# Java 应用镜像由手工或云效流水线构建
# Compose 只消费镜像，不在部署目录内执行 build
META_AI_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/meta-ai-agent:latest

# 宿主机端口规划
# 只修改左侧宿主机端口，容器内端口由服务协议固定
# 当前 Ollama 栈统一使用 18000 ~ 18009
# 端口映射格式为 宿主机端口:容器内端口，局域网访问的是宿主机端口
# 容器之间通过服务名和容器内端口访问，不受宿主机端口变化影响
# MetaAI Java 应用 HTTP API 宿主机端口
META_AI_AGENT_HOST_PORT=18000
# Ollama HTTP API 宿主机端口
OLLAMA_HOST_PORT=18001
# Redis Stack Redis 协议宿主机端口，运维访问方式：redis-cli -h HOST_IP -p 18002 -a "$REDIS_PASSWORD"
REDIS_HOST_PORT=18002
# Redis Stack Browser 控制台宿主机端口，访问地址：http://HOST_IP:18003/redis-stack/browser
REDIS_STACK_BROWSER_HOST_PORT=18003
# Qdrant HTTP API 宿主机端口，Collections：http://HOST_IP:18004/collections，Dashboard：http://HOST_IP:18004/dashboard
QDRANT_HTTP_HOST_PORT=18004
# Qdrant gRPC API 宿主机端口
# gRPC 主要给 SDK / 高性能客户端使用，不用于浏览器访问
QDRANT_GRPC_HOST_PORT=18005
# RustFS S3 API 宿主机端口
RUSTFS_API_HOST_PORT=18006
# RustFS Console 宿主机端口，访问地址：http://HOST_IP:18007/rustfs/console/browser
RUSTFS_CONSOLE_HOST_PORT=18007
# PaddleX OCR HTTP 服务宿主机端口
PADDLEX_OCR_HOST_PORT=18008
# live-asr FunASR WebSocket 服务宿主机端口
LIVE_ASR_HOST_PORT=18009

# Redis Stack 是基础设施服务自身配置
# 该镜像包含 RediSearch、RedisJSON 和 Redis Stack Browser，不能替换成普通 redis 镜像
# Compose 中通过 REDIS_ARGS 开启 AOF：appendonly yes
# appendfsync everysec 表示每秒刷盘一次，异常退出时通常最多丢最近约 1 秒写入
REDIS_IMAGE=redis/redis-stack:7.4.0-v8

# Redis 访问密码，同时用于 REDIS_ARGS 和健康检查
# 修改后必须同步修改 .data/config/application.properties 中的 Redis 密码
# 检查持久化：docker compose exec redis-stack redis-cli -a "$REDIS_PASSWORD" CONFIG GET appendonly appendfsync
# 检查文件：docker compose exec redis-stack sh -c 'ls -lah /data'
REDIS_PASSWORD=123456

# Qdrant 用于向量库性能对比，应用是否使用由挂载的 application.properties 决定
QDRANT_IMAGE=qdrant/qdrant:v1.18

# 关闭 Qdrant 匿名遥测
# 单机离线部署不依赖外部观测链路，显式关闭便于企业环境审计
QDRANT_TELEMETRY_DISABLED=true

# Qdrant 服务日志级别
# 排障时可临时改为 DEBUG，稳定运行建议保持 INFO
QDRANT_LOG_LEVEL=INFO

# Qdrant 可打开文件数量上限
# 高并发检索、较多 segment、较大 collection 时默认 nofile 可能过低
QDRANT_ULIMIT_NOFILE_SOFT=65535
QDRANT_ULIMIT_NOFILE_HARD=65535

# RustFS 账号是对象存储服务自身配置
# application.properties 中必须同步填写一致的访问密钥
# 默认端口映射暴露到宿主机所有网卡，局域网可访问
# 访问范围需要通过宿主机防火墙或内网边界控制
# admin / Xc.123456 是离线单机默认凭据，现场部署建议按客户环境改成强密码
RUSTFS_IMAGE=rustfs/rustfs:1.0.0-beta.6
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=Xc.123456

# OCR 和 live-asr 镜像已经预置模型缓存
# Compose 不挂载空模型目录，避免覆盖镜像内模型
PADDLEX_OCR_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/paddlex-ocr:v1.0.0
LIVE_ASR_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/live-asr:v1.0.0

# live-asr 使用 FunASR 2pass WebSocket 实时语音识别
# decoder-thread-num 基本决定最大并发识别路数
# 单机混部不要默认吃满 CPU，现场按 CPU 核数和并发路数调整
FUNASR_DECODER_THREAD_NUM=4

# WebSocket / 网络 IO 线程数
# 低并发单机部署通常 1 ~ 2 即可
FUNASR_IO_THREAD_NUM=2

# 每路识别内部 ONNX 模型线程数
# decoder-thread-num * model-thread-num 建议接近可分配给 ASR 的 CPU 线程数
FUNASR_MODEL_THREAD_NUM=1

# Ollama 栈面向小型工作站
# ollama-init 会按下面两个模型名提前拉取 Chat 和 Embedding 模型
# 修改模型名后必须同步修改 .data/config/application-ollama.properties
# Ollama 使用 .data/ollama 存储模型，不与 vLLM 的 Hugging Face 缓存混用
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CHAT_MODEL=qwen3.6:35b
OLLAMA_EMBEDDING_MODEL=bge-m3
