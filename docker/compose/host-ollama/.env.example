# Docker Compose 内置项目名变量，不需要在 docker-compose.yml 中通过 ${COMPOSE_PROJECT_NAME} 手动引用
# 用于固定 Compose 资源命名前缀，例如默认网络名会是 meta-ai-host-ollama_default
COMPOSE_PROJECT_NAME=meta-ai-host-ollama

# Java 应用镜像由本地 docker build 或流水线构建
# 宿主机本地打包部署时建议使用 meta-ai-agent:local
META_AI_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/meta-ai-agent:2026-06-18

# 宿主机端口规划
# 当前 Host Ollama 栈统一使用 18000 ~ 18010，局域网访问这些宿主机端口
# 宿主机 Ollama 继续使用自身 11434 端口，不纳入 Compose 端口规划
META_AI_AGENT_HOST_PORT=18000
REDIS_HOST_PORT=18003
REDIS_STACK_BROWSER_HOST_PORT=18004
QDRANT_HTTP_HOST_PORT=18005
QDRANT_GRPC_HOST_PORT=18006
RUSTFS_API_HOST_PORT=18007
RUSTFS_CONSOLE_HOST_PORT=18008
PADDLEX_OCR_HOST_PORT=18009
LIVE_ASR_HOST_PORT=18010

# ======================================================================================================================
# ===================================================== Redis Stack ====================================================
# ======================================================================================================================

# Redis Stack 是基础设施服务自身配置
# 该镜像包含 RediSearch、RedisJSON 和 Redis Stack Browser，不能替换成普通 redis 镜像
REDIS_IMAGE=registry.cn-hangzhou.aliyuncs.com/xother/redis-stack:7.4.0-v8

# Redis 访问密码，同时用于 REDIS_ARGS 和健康检查
# 修改后必须同步修改 .data/config/application.properties 中的 Redis 密码
REDIS_PASSWORD=123456

# ======================================================================================================================
# ======================================================== Qdrant ======================================================
# ======================================================================================================================

# Qdrant 用于向量库性能对比，应用是否使用由挂载的 application.properties 决定
QDRANT_IMAGE=registry.cn-hangzhou.aliyuncs.com/xother/qdrant:v1.18

# 关闭 Qdrant 匿名遥测
QDRANT_TELEMETRY_DISABLED=true

# Qdrant 服务日志级别
QDRANT_LOG_LEVEL=INFO

# Qdrant 可打开文件数量上限
QDRANT_ULIMIT_NOFILE_SOFT=65535
QDRANT_ULIMIT_NOFILE_HARD=65535

# ======================================================================================================================
# ======================================================== RustFS ======================================================
# ======================================================================================================================

# RustFS 账号是对象存储服务自身配置
# application.properties 中必须同步填写一致的访问密钥
RUSTFS_IMAGE=registry.cn-hangzhou.aliyuncs.com/xother/rustfs:1.0.0-beta.6
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=Xc.123456

# ======================================================================================================================
# ===================================================== PaddleX OCR ====================================================
# ======================================================================================================================

# PaddleX OCR 镜像已经预置模型缓存
# Compose 不挂载空模型目录，避免覆盖镜像内模型
PADDLEX_OCR_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/paddlex-ocr:v1.0.0

# ======================================================================================================================
# ==================================================== live-asr / FunASR ===============================================
# ======================================================================================================================

# live-asr 镜像已经预置模型缓存
# Compose 不挂载空模型目录，避免覆盖镜像内模型
LIVE_ASR_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/live-asr:v1.0.0

# live-asr 使用 FunASR 2pass WebSocket 实时语音识别
# decoder-thread-num 基本决定最大并发识别路数
FUNASR_DECODER_THREAD_NUM=4

# WebSocket / 网络 IO 线程数
FUNASR_IO_THREAD_NUM=2

# 每路识别内部 ONNX 模型线程数
FUNASR_MODEL_THREAD_NUM=1
