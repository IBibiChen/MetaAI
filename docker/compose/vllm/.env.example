COMPOSE_PROJECT_NAME=meta-ai-vllm

# Java 应用镜像由手工或云效流水线构建
# Compose 只消费镜像，不在部署目录内执行 build
META_AI_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/meta-ai-agent:latest

# 宿主机端口规划
# 只修改左侧宿主机端口，容器内端口由服务协议固定
META_AI_AGENT_HOST_PORT=8008
VLLM_CHAT_HOST_PORT=8000
VLLM_EMBEDDING_HOST_PORT=8001
REDIS_HOST_PORT=6399
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
RUSTFS_API_HOST_PORT=9000
RUSTFS_CONSOLE_HOST_PORT=9001
PADDLEX_OCR_HOST_PORT=18080
LIVE_ASR_HOST_PORT=10096

# Redis Stack 是基础设施服务自身配置
# 该镜像包含 RediSearch 和 RedisJSON，不能替换成普通 redis 镜像
# Compose 中通过 REDIS_ARGS 开启 AOF：appendonly yes
# appendfsync everysec 表示每秒刷盘一次，异常退出时通常最多丢最近约 1 秒写入
REDIS_IMAGE=redis/redis-stack-server:7.4.0-v8

# Redis 访问密码，同时用于 REDIS_ARGS 和健康检查
# 修改后必须同步修改 .data/config/application.properties 中的 Redis 密码
# 检查持久化：docker compose exec redis-stack redis-cli -a "$REDIS_PASSWORD" CONFIG GET appendonly appendfsync
# 检查文件：docker compose exec redis-stack sh -c 'ls -lah /data'
REDIS_PASSWORD=123456

# Qdrant 用于向量库性能对比，应用是否使用由挂载的 application.properties 决定
QDRANT_IMAGE=qdrant/qdrant:v1.18

# 关闭 Qdrant 匿名遥测
# 单机离线部署不依赖外部观测链路，显式关闭便于企业环境审计
QDRANT_TELEMETRY_DISABLED=true

# Qdrant 服务日志级别
# 排障时可临时改为 DEBUG，稳定运行建议保持 INFO
QDRANT_LOG_LEVEL=INFO

# Qdrant 可打开文件数量上限
# 高并发检索、较多 segment、较大 collection 时默认 nofile 可能过低
QDRANT_ULIMIT_NOFILE_SOFT=65535
QDRANT_ULIMIT_NOFILE_HARD=65535

# RustFS 账号是对象存储服务自身配置
# application.properties 中必须同步填写一致的访问密钥
# 默认端口映射暴露到宿主机所有网卡，局域网可访问
# 访问范围需要通过宿主机防火墙或内网边界控制
# admin / Xc.123456 是离线单机默认凭据，现场部署建议按客户环境改成强密码
RUSTFS_IMAGE=rustfs/rustfs:1.0.0-beta.6
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=Xc.123456

# OCR 和 live-asr 镜像已经预置模型缓存
# Compose 不挂载空模型目录，避免覆盖镜像内模型
PADDLEX_OCR_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/paddlex-ocr:v1.0.0
LIVE_ASR_IMAGE=registry.cn-hangzhou.aliyuncs.com/metax/live-asr:v1.0.0

# live-asr 使用 FunASR 2pass WebSocket 实时语音识别
# decoder-thread-num 基本决定最大并发识别路数
# 单机混部不要默认吃满 CPU，现场按 CPU 核数和并发路数调整
FUNASR_DECODER_THREAD_NUM=4

# WebSocket / 网络 IO 线程数
# 低并发单机部署通常 1 ~ 2 即可
FUNASR_IO_THREAD_NUM=2

# 每路识别内部 ONNX 模型线程数
# decoder-thread-num * model-thread-num 建议接近可分配给 ASR 的 CPU 线程数
FUNASR_MODEL_THREAD_NUM=1

# vLLM 栈拆分 Chat 和 Embedding 两个 OpenAI 兼容服务
# 本地开发默认面向 2 张 RTX 4090，张量并行默认值为 2
# 单卡现场部署不能直接沿用 Qwen3.6-27B，必须改成更小模型或量化模型
# 修改 served model name 后必须同步修改 .data/config/application-openai.properties
# cu129 表示容器内 CUDA 用户态为 12.9，宿主机 NVIDIA Driver 必须兼容 CUDA 12.9
# Hugging Face 缓存目录只复用模型资产，不保证不同 OS / CPU 架构都能运行同一镜像
# vLLM OpenAI 兼容服务镜像版本
VLLM_IMAGE=vllm/vllm-openai:v0.23.0-cu129-ubuntu2404

# Chat 实际加载的 Hugging Face 模型 ID 或本地模型路径
VLLM_CHAT_MODEL=Qwen/Qwen3.6-27B

# Chat 暴露给应用侧调用的模型名
# 必须与 .data/config/application-openai.properties 中 chat options model 保持一致
VLLM_CHAT_SERVED_MODEL=Qwen3.6-27B

# Chat 默认关闭 Qwen3 thinking
# Compose 中通过 --default-chat-template-kwargs '{"enable_thinking": false}' 注入
# 如需单次请求开启，可由请求侧通过 chat_template_kwargs.enable_thinking=true 覆盖

# Chat 默认使用 2 张 GPU 做张量并行
# 只有一台机器同时运行 Embedding 时，Chat 显存比例不要贴近 1
# 该变量只限制容器内 vLLM 可见 GPU，不负责跨容器显存调度
VLLM_CHAT_CUDA_VISIBLE_DEVICES=0,1

# Chat 单个 vLLM 实例可使用的 GPU 显存比例
# 2 张 4090 同机运行 Embedding 时建议保留显存余量
VLLM_CHAT_GPU_MEMORY_UTILIZATION=0.88

# Embedding 实际加载的 Hugging Face 模型 ID 或本地模型路径
VLLM_EMBEDDING_MODEL=BAAI/bge-m3

# Embedding 暴露给应用侧调用的模型名
# 必须与 .data/config/application-openai.properties 中 embedding options model 保持一致
VLLM_EMBEDDING_SERVED_MODEL=bge-m3

# Embedding 模型权重固定到 Hugging Face commit，避免重建容器后悄悄拉到新权重
# 向量模型 revision 变更后必须重建向量索引
VLLM_EMBEDDING_REVISION=5617a9f61b028005a4858fdac845db406aefb181

# Embedding 仍使用 GPU，但只作为低显存旁路服务运行
# 当 Chat 使用 0,1 两张卡时，这里会与 Chat 共享 GPU 1
# 如现场有独立 GPU，可改成未被 Chat 使用的设备编号
VLLM_EMBEDDING_CUDA_VISIBLE_DEVICES=1

# Embedding 单个 vLLM 实例可使用的 GPU 显存比例
# 单机共享 GPU 时建议 0.20 ~ 0.30，OOM 时优先降到 0.20
VLLM_EMBEDDING_GPU_MEMORY_UTILIZATION=0.25

# Embedding 最大并发序列数
# 该值越大吞吐越高，但峰值显存和瞬时算力占用也越高
VLLM_EMBEDDING_MAX_NUM_SEQS=16

# Chat 张量并行 GPU 数
# 必须小于或等于 VLLM_CHAT_CUDA_VISIBLE_DEVICES 中的 GPU 数量
# 单卡部署必须改成 1，并同步确认模型是否能放入单卡显存
VLLM_TENSOR_PARALLEL_SIZE=2

# Chat 最大上下文长度，包含 prompt 和输出 token
# 值越大 KV cache 显存占用越高，24GB 级显卡不要盲目拉长
# 8192 是保守默认，低并发 RAG 场景部署后可尝试 16384
# 总 token 预算 = 输入侧 token + 输出侧 token
# 输入侧包括 system prompt、历史对话、RAG 检索内容、用户问题和工具上下文
# 输出侧由应用侧 max-tokens 控制，例如 application-openai.properties 中 max-tokens 为 2048
# 计算示例：总预算 8192 token，输出侧 2048 token，输入侧 ≈ 8192 - 2048 = 6144 token
#
# 粗略换算，不同分词器有差异，仅供估算
# 中文常规估算：1 个汉字 ≈ 0.7 ~ 1.3 token，1 token ≈ 0.8 ~ 1.4 个汉字
# 中文字符数 ≈ token 数 * 0.75 ~ token 数 * 1.5
# 例如 8192 token ≈ 8192 * 0.75 ~ 8192 * 1.5 ≈ 6000 ~ 12000 个中文字符
# 中文保守预算：OCR、表格、数字、英文混排较多时，可按 1 个汉字 ≈ 1 ~ 1.5 token 预估
#
# 英文常规估算：1 个英文字符 ≈ 0.25 ~ 0.33 token，1 token ≈ 3 ~ 4 个英文字符，约 0.75 个单词
# 英文字符数 ≈ token 数 * 3 ~ token 数 * 4
# 英文单词数 ≈ token 数 * 0.75
# 例如 8192 token ≈ 8192 * 3 ~ 8192 * 4 ≈ 24000 ~ 32000 个英文字符
#
# 粗略估算
# 8192 token ≈ 6000 ~ 12000 个中文字符，或 24000 ~ 32000 个英文字符
# 6144 token ≈ 4500 ~ 9000 个中文字符，或 18000 ~ 24000 个英文字符
# Qwen3.6-27B 原生上下文为 262144 token，可扩展到约 1010000 token
# 官方 262144 token vLLM 示例使用 8 卡张量并行，本机 2 张 4090 不应直接照搬
# 2 张 4090 不等于单张 48GB 显卡，调大后需要观察 vLLM 日志和 nvidia-smi
VLLM_MAX_MODEL_LEN=8192

# 私有 Hugging Face 模型需要填写 token
# 公开模型可保持为空
HF_TOKEN=
